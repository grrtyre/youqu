{
  "name": "screen-ruler",
  "version": "1.1.1",
  "description": "屏幕尺管家 - 屏幕测量与标注工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/test.js",
    "dist": "electron-builder --win --x64",
    "icon": "python build/make_icon.py"
  },
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.youqu.screenruler",
    "productName": "屏幕尺管家",
    "directories": {
      "output": "dist-v1.1.1"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "屏幕尺管家"
    }
  }
}
