{
  "name": "screen-ruler",
  "version": "1.1.0",
  "description": "屏幕标尺管家 - 一站式屏幕测量工具（标尺/框选/距离/量角器/放大镜/截图标注）",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/test.js",
    "dist": "electron-builder --win --x64"
  },
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.youqu.screenruler",
    "productName": "屏幕标尺管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "屏幕标尺管家"
    }
  }
}
