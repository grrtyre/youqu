<Window x:Class="AlarmManager.Portable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="闹钟管家" Height="480" Width="360"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Deactivated="Window_Deactivated">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="14"
            Margin="6"
            BorderBrush="#e5e5ea"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Border.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============ 列表视图 ============ -->
            <Grid x:Name="ListPanel" Grid.Row="0" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Padding="16,14" Background="White"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#f0f0f2" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="闹钟管家" FontFamily="{StaticResource AppleFont}"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="NextAlarmText" Text="无闹钟" FontFamily="{StaticResource AppleFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button x:Name="BtnAdd" Grid.Column="1" Style="{StaticResource IconButton}"
                                Click="BtnAdd_Click" ToolTip="新建闹钟"
                                Content="+" FontSize="22" FontWeight="Light" Width="32" Height="32" Margin="0,0,4,0">
                            <Button.Foreground>
                                <SolidColorBrush Color="{StaticResource AppleBlueColor}"/>
                            </Button.Foreground>
                        </Button>
                        <Button x:Name="BtnClose" Grid.Column="2" Style="{StaticResource IconButton}"
                                Click="BtnClose_Click" ToolTip="隐藏到托盘 (Ctrl+Alt+A)"
                                Content="×" FontSize="22" FontWeight="Light" Width="32" Height="32"/>
                    </Grid>
                </Border>

                <!-- 闹钟列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12" Style="{StaticResource ThinScrollBar}">
                    <StackPanel x:Name="AlarmListPanel">
                        <!-- 列表项由代码动态生成 -->
                    </StackPanel>
                </ScrollViewer>

                <!-- 空状态 -->
                <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="0,-30,0,0">
                    <TextBlock Text="⏰" FontSize="56" HorizontalAlignment="Center" Opacity="0.25"/>
                    <TextBlock Text="暂无闹钟" FontFamily="{StaticResource AppleFont}"
                               FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="点击右上角 + 创建你的第一个闹钟"
                               FontFamily="{StaticResource AppleFont}" FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 底部状态栏 -->
                <Border Grid.Row="2" Padding="16,10" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="0,0,14,14"
                        BorderBrush="#f0f0f2" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StatsText" Grid.Column="0"
                                   Text="0 个闹钟" FontFamily="{StaticResource AppleFont}"
                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Click="BtnSettings_Click"
                                Content="⚙" FontSize="14" ToolTip="设置" Width="28" Height="28"/>
                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Click="BtnExit_Click"
                                Content="⏻" FontSize="14" ToolTip="退出" Width="28" Height="28"
                                Foreground="{StaticResource DangerBrush}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ 编辑视图 ============ -->
            <Grid x:Name="EditPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Padding="16,14" Background="White"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#f0f0f2" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource IconButton}" Click="BtnCancelEdit_Click"
                                Content="←" FontSize="18" Width="30" Height="30"/>
                        <TextBlock Grid.Column="1" x:Name="EditTitle" Text="新建闹钟"
                                   FontFamily="{StaticResource AppleFont}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Click="BtnSaveEdit_Click"
                                Content="✓" FontSize="18" Width="30" Height="30">
                            <Button.Foreground>
                                <SolidColorBrush Color="{StaticResource AppleBlueColor}"/>
                            </Button.Foreground>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">
                    <StackPanel>

                        <!-- 大时钟显示 -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <StackPanel HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBox x:Name="EditHour" Text="07" Width="64" FontSize="42" FontWeight="Light"
                                             FontFamily="{StaticResource AppleFont}" HorizontalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,2,0"
                                             VerticalAlignment="Center" Padding="0,0,0,0"/>
                                    <TextBlock Text=":" FontSize="42" FontWeight="Light"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="2,4,2,0"/>
                                    <TextBox x:Name="EditMinute" Text="00" Width="64" FontSize="42" FontWeight="Light"
                                             FontFamily="{StaticResource AppleFont}" HorizontalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="{StaticResource TextPrimaryBrush}" Margin="2,0,0,0"
                                             VerticalAlignment="Center" Padding="0,0,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="EditRepeatPreview" Text="一次性"
                                           FontFamily="{StaticResource AppleFont}" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 标签输入 -->
                        <TextBlock Text="标签" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <TextBox x:Name="EditLabel" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"
                                 Text="闹钟" />

                        <!-- 重复模式 -->
                        <TextBlock Text="重复" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <ComboBox x:Name="EditRepeat" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,8"
                                  SelectionChanged="EditRepeat_SelectionChanged">
                            <ComboBoxItem Content="一次性" Tag="once"/>
                            <ComboBoxItem Content="每天" Tag="daily"/>
                            <ComboBoxItem Content="工作日" Tag="weekdays"/>
                            <ComboBoxItem Content="周末" Tag="weekend"/>
                            <ComboBoxItem Content="自定义" Tag="custom"/>
                            <ComboBoxItem Content="农历每年" Tag="lunar-annual"/>
                            <ComboBoxItem Content="农历一次性" Tag="lunar-once"/>
                        </ComboBox>

                        <!-- 自定义周几 -->
                        <StackPanel x:Name="WeekdaysPanel" Orientation="Horizontal" Margin="0,0,0,12"
                                    Visibility="Collapsed">
                            <ToggleButton x:Name="WdMon" Content="一" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdTue" Content="二" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdWed" Content="三" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdThu" Content="四" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdFri" Content="五" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdSat" Content="六" Width="36" Height="32" Margin="0,0,4,0"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                            <ToggleButton x:Name="WdSun" Content="日" Width="36" Height="32"
                                          FontFamily="{StaticResource AppleFont}" FontSize="12"/>
                        </StackPanel>

                        <!-- 农历配置 -->
                        <StackPanel x:Name="LunarPanel" Margin="0,0,0,12" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="LunarMonthCombo" Style="{StaticResource ComboBoxStyle}" Width="100" Margin="0,0,8,0">
                                    <ComboBoxItem Content="正月" Tag="1"/>
                                    <ComboBoxItem Content="二月" Tag="2"/>
                                    <ComboBoxItem Content="三月" Tag="3"/>
                                    <ComboBoxItem Content="四月" Tag="4"/>
                                    <ComboBoxItem Content="五月" Tag="5"/>
                                    <ComboBoxItem Content="六月" Tag="6"/>
                                    <ComboBoxItem Content="七月" Tag="7"/>
                                    <ComboBoxItem Content="八月" Tag="8"/>
                                    <ComboBoxItem Content="九月" Tag="9"/>
                                    <ComboBoxItem Content="十月" Tag="10"/>
                                    <ComboBoxItem Content="冬月" Tag="11"/>
                                    <ComboBoxItem Content="腊月" Tag="12"/>
                                </ComboBox>
                                <ComboBox x:Name="LunarDayCombo" Style="{StaticResource ComboBoxStyle}" Width="100">
                                    <!-- 由代码动态填充 -->
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="IsLeapCheck" Content="闰月" Margin="0,8,0,0"
                                      FontFamily="{StaticResource AppleFont}" FontSize="12"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- 铃声 -->
                        <TextBlock Text="铃声" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <ComboBox x:Name="EditSound" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,12">
                            <ComboBoxItem Content="🔔 风铃" Tag="chime"/>
                            <ComboBoxItem Content="🛎 钟声" Tag="bell"/>
                            <ComboBoxItem Content="🎵 马林巴" Tag="marimba"/>
                            <ComboBoxItem Content="📣 蜂鸣" Tag="buzzer"/>
                            <ComboBoxItem Content="🐦 鸟鸣" Tag="birdsong"/>
                        </ComboBox>

                        <!-- 贪睡 -->
                        <TextBlock Text="贪睡（分钟）" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <TextBox x:Name="EditSnooze" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,4"
                                 Text="5"/>

                        <TextBlock Text="最大贪睡次数" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <TextBox x:Name="EditMaxSnooze" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"
                                 Text="3"/>

                        <!-- 音量 -->
                        <TextBlock Text="音量" Style="{StaticResource CaptionText}" Margin="2,4,0,4"/>
                        <Slider x:Name="EditVolume" Minimum="0" Maximum="100" Value="90" Margin="0,4,0,12"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>

                        <!-- 启用开关 -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="启用此闹钟" Style="{StaticResource BodyText}"/>
                                    <TextBlock Text="关闭后此闹钟不会触发" Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="EditEnabled" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- 底部操作 -->
                <Border Grid.Row="2" Padding="14,12" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="0,0,14,14"
                        BorderBrush="#f0f0f2" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource DangerButton}" Click="BtnDeleteEdit_Click"
                                Content="🗑 删除" Margin="0,0,8,0" x:Name="BtnDeleteEdit"/>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Click="BtnSaveEdit_Click"
                                Content="保存"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ 设置视图 ============ -->
            <Grid x:Name="SettingsPanel" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,14" Background="White"
                        CornerRadius="14,14,0,0"
                        BorderBrush="#f0f0f2" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource IconButton}" Click="BtnCloseSettings_Click"
                                Content="←" FontSize="18" Width="30" Height="30"/>
                        <TextBlock Grid.Column="1" Text="设置"
                                   FontFamily="{StaticResource AppleFont}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">
                    <StackPanel>
                        <!-- 渐强音量 -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="渐强音量" Style="{StaticResource BodyText}"/>
                                    <CheckBox Grid.Column="1" x:Name="SetFadeIn" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <TextBlock Text="触发后音量从 0 渐进至最大，避免突然大声"
                                           Style="{StaticResource CaptionText}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 系统通知 -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="桌面通知" Style="{StaticResource BodyText}"/>
                                    <TextBlock Text="触发时显示 Windows 通知" Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="SetNotify" Style="{StaticResource ToggleSwitch}"/>
                            </Grid>
                        </Border>

                        <!-- 触发时置顶 -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="触发时置顶" Style="{StaticResource BodyText}"/>
                                    <TextBlock Text="闹钟响铃窗口置顶显示" Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" x:Name="SetFront" Style="{StaticResource ToggleSwitch}"/>
                            </Grid>
                        </Border>

                        <!-- 数据管理 -->
                        <TextBlock Text="数据管理" Style="{StaticResource CaptionText}" Margin="2,8,0,4"/>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Button Style="{StaticResource SecondaryButton}" Click="BtnExport_Click"
                                        Content="📤 导出 JSON" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Style="{StaticResource SecondaryButton}" Click="BtnImport_Click"
                                        Content="📥 导入 JSON" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Style="{StaticResource DangerButton}" Click="BtnClearLogs_Click"
                                        Content="🗑 清空触发历史" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- 关于 -->
                        <TextBlock Text="关于" Style="{StaticResource CaptionText}" Margin="2,8,0,4"/>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="闹钟管家便携版 v1.0.0" Style="{StaticResource BodyText}"/>
                                <TextBlock Text="原生 .NET 8 WPF · 零 Electron · 输入法式体验"
                                           Style="{StaticResource CaptionText}" Margin="0,4,0,8"/>
                                <TextBlock Text="☕ 支持我们" Style="{StaticResource BodyText}" Margin="0,4,0,4"/>
                                <TextBlock>
                                    <Hyperlink NavigateUri="https://www.ifdian.net/a/giquwei" RequestNavigate="Link_RequestNavigate">
                                        爱发电 · giquwei
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 鸣谢 -->
                        <TextBlock Text="🙏 鸣谢" Style="{StaticResource BodyText}" Margin="2,12,0,4"/>
                        <Border Style="{StaticResource CardStyle}">
                            <TextBlock Text="感谢以下朋友的支持（按支持时间排序）：&#x0a;_暂无，期待第一个支持者的出现。_"
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="14,12" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="0,0,14,14"
                        BorderBrush="#f0f0f2" BorderThickness="0,1,0,0">
                    <Button Style="{StaticResource PrimaryButton}" Click="BtnCloseSettings_Click"
                            Content="完成" HorizontalAlignment="Stretch"/>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
