<Window x:Class="AlarmManager.Portable.TriggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="闹钟触发" Width="360" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="14"
            Margin="6"
            BorderBrush="#e5e5ea"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Padding="18,12"
                    CornerRadius="14,14,0,0"
                    Background="{StaticResource AppleBlueBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⏰ 闹钟触发"
                               FontFamily="{StaticResource AppleFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="White"/>
                    <Button Grid.Column="1" Click="BtnClose_Click"
                            Content="×" FontSize="18" Width="24" Height="24"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 中间内容 -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="18,8">
                <TextBlock x:Name="TimeText" Text="07:30"
                           FontFamily="{StaticResource AppleFont}" FontSize="48" FontWeight="Light"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="LabelText" Text="起床"
                           FontFamily="{StaticResource AppleFont}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,4"/>
                <TextBlock x:Name="RepeatText" Text="每天"
                           FontFamily="{StaticResource AppleFont}" FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 底部操作按钮 -->
            <Border Grid.Row="2" Padding="14,12"
                    CornerRadius="0,0,14,14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#f0f0f2" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Click="BtnSnooze_Click"
                            Content="💤 贪睡" Margin="0,0,6,0" x:Name="BtnSnooze"/>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Click="BtnDismiss_Click"
                            Content="✓ 确定" Margin="6,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
