{
  "name": "alarm-manager",
  "productName": "闹钟管家",
  "version": "1.0.0",
  "description": "本地优先的多闹钟桌面管家：多闹钟管理、每日/工作日/周末/自定义重复、农历闹钟、Web Audio 合成铃声（零外部资源）、贪睡模式（次数上限）、渐强音量、桌面通知、托盘常驻、全局快捷键，纯本地隐私优先",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/",
    "dev": "electron . --show"
  },
  "keywords": [
    "alarm",
    "clock",
    "reminder",
    "lunar",
    "electron",
    "desktop",
    "windows"
  ],
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0"
  },
  "build": {
    "appId": "com.youqu.alarm-manager",
    "productName": "闹钟管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "闹钟管家"
    }
  }
}
