{
  "name": "subscription-manager",
  "version": "1.1.0",
  "description": "订阅管家 - 追踪你的所有订阅服务，管理周期性支出和续费提醒",
  "main": "src/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "test": "node test/test.js",
    "build": "electron-builder --win --x64"
  },
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.youqu.subscription-manager",
    "productName": "订阅管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "订阅管家 Setup ${version}.${ext}"
    },
    "portable": {
      "artifactName": "订阅管家 ${version}.${ext}"
    }
  }
}
