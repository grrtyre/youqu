{
  "name": "unit-converter-manager",
  "version": "1.0.0",
  "description": "换算管家 - 本地离线多类别单位换算桌面工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/test.js",
    "dist": "electron-builder --win --x64"
  },
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.youqu.unitconverter",
    "productName": "换算管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "换算管家 Setup ${version}.exe"
    },
    "portable": {
      "artifactName": "换算管家 ${version}.exe"
    }
  }
}
