{
  "name": "startup-manager",
  "version": "1.0.0",
  "description": "启动项管家 - Windows 启动项可视化管理桌面应用",
  "main": "src/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "test": "node test/test.js",
    "pack": "electron-builder --win --x64"
  },
  "author": "youqu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.youqu.startup-manager",
    "productName": "启动项管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
